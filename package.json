{
  "name": "textlint-rule-preset-swift-docs-ja",
  "version": "1.0.2",
  "description": "Swift 日本語ドキュメント向けの textlint ルールプリセット",
  "type": "module",
  "author": "Koutarou ISHIKAWA",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "textlint",
    "textlint-rule",
    "swift",
    "docs",
    "ja",
    "translation",
    "vite",
    "preset",
    "vscode"
  ],
  "main": "index.cjs",
  "exports": {
    ".": {
      "require": "./index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/sync-vscode-version.mjs && vite build && cp dist/index.cjs index.cjs && node scripts/copy-root-cjs-chunks.mjs",
    "dev": "vite build --watch",
    "extract": "node dist/scripts/extract-terms.js",
    "watch": "node dist/scripts/watch-terms.js",
    "lint": "echo 'Note: This preset project does not include test documents. To test the preset, install it in another project and use it there.'",
    "prepack": "npm run build",
    "pack": "node scripts/pack-to-artifacts.mjs",
    "verify:pack": "node scripts/verify-pack.mjs",
    "publish:npm": "node scripts/publish-to-npm.mjs",
    "vscode:package": "cd dist/vscode && npm install --production && npx vsce package"
  },
  "files": [
    "index.cjs",
    "chunk-*.cjs",
    "dist",
    "dict",
    "prh-rules"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stein2nd/textlint-rule-preset-swift-docs-ja.git"
  },
  "bugs": {
    "url": "https://github.com/stein2nd/textlint-rule-preset-swift-docs-ja/issues"
  },
  "homepage": "https://github.com/stein2nd/textlint-rule-preset-swift-docs-ja#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "textlint": ">=14.0.0"
  },
  "overrides": {
    "rollup": "^4.62.2"
  },
  "devDependencies": {
    "@textlint-ja/textlint-rule-no-synonyms": "^1.3.0",
    "@textlint/kernel": "^15.7.1",
    "@textlint/textlint-plugin-markdown": "^15.7.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "js-yaml": "^5.2.1",
    "rollup": "^4.62.2",
    "textlint": "^15.7.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-ja-hiragana-keishikimeishi": "^1.1.0",
    "textlint-rule-ja-no-abusage": "^3.0.0",
    "textlint-rule-ja-no-redundant-expression": "^4.0.1",
    "textlint-rule-ja-space-around-code": "^3.0.2",
    "textlint-rule-ja-space-between-half-and-full-width": "^3.0.2",
    "textlint-rule-max-kanji-continuous-len": "^1.1.1",
    "textlint-rule-no-doubled-joshi": "^5.1.1",
    "textlint-rule-no-dropping-the-ra": "^3.0.0",
    "textlint-rule-no-mixed-zenkaku-and-hankaku-alphabet": "^1.0.1",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-prh": "^6.1.0",
    "textlint-rule-terminology": "^5.2.16",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
